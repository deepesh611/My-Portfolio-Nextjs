# Copy this file to .env.local and fill in the values
# .env.local is gitignored — your keys will NOT be committed

# Password for protected pages/routes
PAGE_ACCESS_PASSWORD=any_password

# Google Drive API – used for the Gallery page
# Get your API key at: https://console.cloud.google.com → Enable Drive API → Create API Key
GOOGLE_DRIVE_API_KEY=your_google_drive_api_key_here
